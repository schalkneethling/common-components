{
  "name": "fiori-common-components",
  "description": "A collection of commonly used components with no external dependencies.",
  "packageManager": "pnpm@11.1.0",
  "type": "module",
  "version": "0.0.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "vite",
    "prettier:lint": "prettier .",
    "prettier:format": "prettier --write .",
    "svg:sprite": "svg-symbol-sprite -i ./components/svg-icon/icons/ -o ./components/svg-icon/sprite.svg",
    "lint:js": "eslint .",
    "lint:css": "stylelint **/*.css",
    "test": "vitest",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:chromium": "playwright test --project=chromium"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.5.3",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "svg-symbol-sprite": "^1.5.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^4.1.8"
  }
}
